# OUTSIDE environment configuration
# Copy to .env.local for development. Development can use explicit in-memory
# storage; production requires durable PostgreSQL and strong secrets.

# Base URL used in email and provider redirects
APP_URL=http://localhost:3000

# Persistence. Production must use database mode.
# DATABASE_URL=postgresql://user:pass@localhost:5432/outside
# OUTSIDE_STORAGE_MODE=database
# PRISMA_LOG_QUERIES=false

# Authentication and verification. Use independent random values of at least
# 32 bytes in production. AUTH_SECRET_PREVIOUS is for rotation only.
# AUTH_SECRET=
# AUTH_SECRET_PREVIOUS=
# OUTSIDE_VERIFY_SECRET=

# Optional Google OpenID Connect
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Scheduled monitoring. Caller sends Authorization: Bearer <CRON_SECRET>.
# CRON_SECRET=
# GUARDIAN_RETENTION_BATCH_SIZE=2000
# GUARDIAN_RETENTION_MAX_BATCHES=10
# OUTSIDE_EMAIL_OUTBOX_RETENTION_DAYS=90
# OUTSIDE_WEBHOOK_IDEMPOTENCY_DAYS=400
# OUTSIDE_USAGE_RETENTION_DAYS=730

# Transactional email. Without a key, development uses the console transport.
# RESEND_API_KEY=
# EMAIL_FROM=OUTSIDE <alerts@yourdomain.com>

# Guardian integration credentials are encrypted at rest with AES-256-GCM.
# Generate 32 random bytes, encoded as base64 or 64 hexadecimal characters.
# GUARDIAN_ENCRYPTION_KEY=

# Enterprise control plane. Use an independent 32-byte AES key. The platform
# provisioning token is a high-privilege automation secret and must be at least
# 32 bytes in production. Pin each regional deployment to its served region.
# ENTERPRISE_ENCRYPTION_KEY=
# ENTERPRISE_ENCRYPTION_KEY_PREVIOUS=
# ENTERPRISE_PROVISIONING_TOKEN=
# ENTERPRISE_SELF_SERVICE_TRIAL=false
# ENTERPRISE_BREAK_GLASS_EMAILS=security-owner@example.com
# AUDIT_IP_SALT=
# OUTSIDE_DATA_REGION=eu

# Optional OpenTelemetry OTLP/HTTP metrics export. When unset, instrumentation
# remains a no-op. Keep labels low-cardinality; OUTSIDE never exports tenant ids.
# OTEL_SERVICE_NAME=outside
# OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=https://otel-collector.example.com/v1/metrics
# OTEL_EXPORTER_OTLP_HEADERS=authorization=Bearer%20token
# OTEL_METRIC_EXPORT_INTERVAL_MS=60000

# Optional read-only AI explanations
# ANTHROPIC_API_KEY=
# OUTSIDE_AI_MODEL=claude-sonnet-5

# Optional Stripe billing
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_PROFESSIONAL=price_...
# STRIPE_PRICE_AGENCY=price_...

# Optional public-provider overrides (HTTPS only)
# OUTSIDE_CT_ENDPOINT=https://crt.sh
# OUTSIDE_DOH_ENDPOINT=https://cloudflare-dns.com/dns-query
# OUTSIDE_DNS_CACHE_TTL_MS=30000
# OUTSIDE_DNS_CACHE_ENTRIES=2000

# Scan controls
# OUTSIDE_MAX_HOSTS_PER_SCAN=60
# Maximum verified-domain HTTPS/TLS observations per scan (1-12).
# OUTSIDE_MAX_ACTIVE_HOSTS=6
# OUTSIDE_SCANS_PER_MINUTE=12

# Agency Suite licensed seat ceiling (active seats + pending seat invites).
# OUTSIDE_AGENCY_SEAT_LIMIT=100

# Trust forwarding headers only behind a proxy that strips caller-supplied copies.
# Vercel's forwarding header is handled automatically.
# OUTSIDE_TRUST_PROXY=false
