# OUTSIDE environment configuration
# Copy to .env.local for development. The core (passive discovery + demo mode +
# accounts on the in-memory store) runs with NO configuration at all — every
# variable below is optional and unlocks durability or an external capability.

# --- Base URL (used in emails, Stripe redirects) ---
# APP_URL=http://localhost:3000

# --- Persistence (durable accounts, monitors, temporal tracking) ---
# Production requires DATABASE_URL by default. For an intentional ephemeral demo,
# set OUTSIDE_STORAGE_MODE=memory explicitly. Development/test default to memory.
# DATABASE_URL=postgresql://user:pass@localhost:5432/outside
# OUTSIDE_STORAGE_MODE=database
# PRISMA_LOG_QUERIES=false

# --- Auth ---
# Secret used to sign session cookies. MUST be set to a long random value in prod.
# AUTH_SECRET=change-me-to-a-long-random-string
# Comma-separated old secrets accepted only while rotating AUTH_SECRET.
# AUTH_SECRET_PREVIOUS=
# Secret used to sign domain-verification tokens.
# OUTSIDE_VERIFY_SECRET=another-long-random-string
# Google OAuth (optional): the "Continue with Google" button appears only when set.
# Redirect URI: <APP_URL>/api/auth/oauth/google/callback
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# --- Scheduled monitoring ---
# Bearer secret required by GET /api/cron/scan. Point Vercel Cron / a timer at it.
# CRON_SECRET=cron-shared-secret

# --- Email (transactional + change alerts) ---
# Without RESEND_API_KEY, emails are logged to the console (dev transport).
# RESEND_API_KEY=
# EMAIL_FROM=OUTSIDE <alerts@yourdomain.com>

# --- AI explanation layer (optional) ---
# Deterministic discovery/scoring never depend on this. Absent = templated summaries.
# ANTHROPIC_API_KEY=
# OUTSIDE_AI_MODEL=claude-sonnet-5

# --- Billing (Stripe) ---
# Without STRIPE_SECRET_KEY, billing is disabled and only the free plan is active.
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_PROFESSIONAL=price_...
# STRIPE_PRICE_AGENCY=price_...

# --- Public data providers (optional overrides) ---
# OUTSIDE_CT_ENDPOINT=https://crt.sh
# OUTSIDE_DOH_ENDPOINT=https://cloudflare-dns.com/dns-query

# --- Scan safety limits (optional overrides of built-in defaults) ---
# OUTSIDE_MAX_HOSTS_PER_SCAN=60
# OUTSIDE_SCANS_PER_MINUTE=12

# Trust x-real-ip only when a reverse proxy strips caller-supplied copies.
# Vercel deployments use Vercel's overwritten forwarding header automatically.
# OUTSIDE_TRUST_PROXY=false
