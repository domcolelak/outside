# OUTSIDE environment configuration
# Copy to .env.local for development. The core (passive discovery + demo mode)
# runs with NO configuration at all — every variable below is optional and only
# unlocks roadmap capabilities documented in the README.

# --- Public data providers (optional overrides) ---
# Certificate Transparency query endpoint (default: crt.sh)
# OUTSIDE_CT_ENDPOINT=https://crt.sh
# DNS-over-HTTPS resolver (default: Cloudflare)
# OUTSIDE_DOH_ENDPOINT=https://cloudflare-dns.com/dns-query

# --- AI explanation layer (optional, roadmap) ---
# Deterministic discovery/scoring never depend on this. Used only to render
# plain-English executive summaries. Absent = templated summaries are used.
# ANTHROPIC_API_KEY=

# --- Persistence (optional, roadmap: temporal tracking + change detection) ---
# DATABASE_URL=postgresql://user:pass@localhost:5432/outside

# --- Billing (optional, roadmap) ---
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# --- Scan safety limits (optional overrides of built-in defaults) ---
# OUTSIDE_MAX_HOSTS_PER_SCAN=60
# OUTSIDE_SCANS_PER_MINUTE=12
