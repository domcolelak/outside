# Copy to the repository root as .env.staging, restrict it to the operator,
# and replace every CHANGE_ME value with an independent secret.
OUTSIDE_IMAGE=outside:0.2.0-rc.1
OUTSIDE_MIGRATOR_IMAGE=outside-migrator:0.2.0-rc.1
OUTSIDE_BACKUP_IMAGE=outside-backup:0.2.0-rc.1
STAGING_DOMAIN=outside.test
APP_URL=https://outside.test:8443
HTTPS_PORT=8443

POSTGRES_PASSWORD=CHANGE_ME_32_RANDOM_BYTES
AUTH_SECRET=CHANGE_ME_INDEPENDENT_32_RANDOM_BYTES
OUTSIDE_VERIFY_SECRET=CHANGE_ME_INDEPENDENT_32_RANDOM_BYTES
CRON_SECRET=CHANGE_ME_INDEPENDENT_32_RANDOM_BYTES
RESEND_API_KEY=CHANGE_ME_STAGING_RESEND_API_KEY
EMAIL_FROM=OUTSIDE Staging <outside-staging@example.invalid>
GUARDIAN_ENCRYPTION_KEY=CHANGE_ME_BASE64_OR_HEX_32_BYTE_KEY
ENTERPRISE_ENCRYPTION_KEY=CHANGE_ME_DIFFERENT_BASE64_OR_HEX_32_BYTE_KEY
ENTERPRISE_PROVISIONING_TOKEN=CHANGE_ME_INDEPENDENT_32_RANDOM_BYTES
AUDIT_IP_SALT=CHANGE_ME_INDEPENDENT_16_RANDOM_BYTES
BACKUP_ENCRYPTION_KEY=CHANGE_ME_NATIVE_AGE_SECRET_IDENTITY
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_INDEPENDENT_24_RANDOM_BYTES

OUTSIDE_DATA_REGION=eu
OUTSIDE_EMAIL_IMMEDIATE_DELIVERY=false
OUTSIDE_TRUST_PROXY=true
GRAFANA_PORT=3001
BACKUP_INTERVAL_SECONDS=86400
BACKUP_RETENTION_DAYS=14
SCHEDULER_SCAN_INTERVAL_SECONDS=300
SCHEDULER_AGENCY_INTERVAL_SECONDS=600
SCHEDULER_ENTERPRISE_INTERVAL_SECONDS=60
SCHEDULER_RETENTION_INTERVAL_SECONDS=86400
SCHEDULER_KEV_INTERVAL_SECONDS=86400
SCHEDULER_EPSS_INTERVAL_SECONDS=86400

# --- Optional, operator-supplied provider keys ---
# Each feature is env-gated and inactive until its key is set. Leave blank to disable.
# Google sign-in (redirect URI: https://<host>/api/auth/oauth/google/callback):
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# AI explanations (deterministic template used when unset):
OPENAI_API_KEY=
# Threat-intelligence + telemetry (verified-target scans only):
ABUSEIPDB_API_KEY=
HIBP_API_KEY=
GREYNOISE_API_KEY=
VIRUSTOTAL_API_KEY=
SECURITYTRAILS_API_KEY=
SHODAN_API_KEY=
CENSYS_API_ID=
CENSYS_API_SECRET=
# Stripe billing:
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PROFESSIONAL=
STRIPE_PRICE_AGENCY=
