{
  "name": "outside",
  "version": "0.2.0-rc.1",
  "packageManager": "npm@11.16.0",
  "engines": {
    "node": ">=24.18.0 <25",
    "npm": ">=11.16.0 <12"
  },
  "private": true,
  "description": "OUTSIDE - External digital exposure visualization platform. See your company from the outside.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "start:standalone": "node scripts/start-standalone.mjs",
    "lint": "eslint . --cache --cache-strategy content --cache-location .eslintcache --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:browser": "playwright test",
    "test:migration-upgrade": "node scripts/test-migration-upgrade.mjs",
    "test:watch": "vitest",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate deploy",
    "db:validate": "prisma validate",
    "audit:licenses": "node scripts/license-audit.mjs",
    "audit:secrets": "node scripts/secret-scan.mjs",
    "validate:operations": "node --check scripts/measure-http.mjs && node --check ops/staging/scheduler/scheduler.mjs && node --check ops/staging/scheduler/alert-sink.mjs && node -e \"JSON.parse(require('fs').readFileSync('ops/staging/observability/grafana/dashboards/outside-operations.json','utf8'))\"",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.220.0",
    "@opentelemetry/resources": "^2.9.0",
    "@opentelemetry/sdk-metrics": "^2.9.0",
    "@prisma/adapter-pg": "7.9.0",
    "@prisma/client": "7.9.0",
    "@react-pdf/renderer": "4.5.1",
    "next": "^16.2.11",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "stripe": "^22.3.2",
    "tldts": "^7.4.9"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@playwright/test": "1.61.1",
    "@tailwindcss/postcss": "^4.3.3",
    "@types/node": "^24.0.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9.39.5",
    "eslint-config-next": "^16.2.11",
    "postcss": "8.5.20",
    "prisma": "7.9.0",
    "tailwindcss": "^4.3.3",
    "typescript": "5.6.2",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "postcss": "8.5.20",
    "@hono/node-server": "1.19.13",
    "sharp": "^0.35.0",
    "find-my-way": "^9.7.0"
  }
}
