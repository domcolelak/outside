{
  "name": "outside",
  "version": "0.1.0",
  "private": true,
  "description": "OUTSIDE - External digital exposure visualization platform. See your company from the outside.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint app components lib e2e instrumentation.ts vitest.config.ts vitest.e2e.config.ts --ext .ts,.tsx --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:watch": "vitest",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate deploy",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.220.0",
    "@opentelemetry/resources": "^2.9.0",
    "@opentelemetry/sdk-metrics": "^2.9.0",
    "@prisma/client": "^5.22.0",
    "@react-pdf/renderer": "4.5.1",
    "next": "15.5.20",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "stripe": "^17.7.0",
    "tldts": "^7.4.8"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "15.5.20",
    "postcss": "8.5.19",
    "prisma": "^5.22.0",
    "tailwindcss": "3.4.13",
    "typescript": "5.6.2",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "postcss": "8.5.19"
  }
}
