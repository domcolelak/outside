// OUTSIDE persistence schema (PostgreSQL).
//
// Temporal design: a stable AssetIdentity per (target, canonical) survives an
// asset disappearing and returning across scans; AssetSnapshot captures the
// asset's observed state in each individual scan. Change detection is a diff of
// consecutive snapshot sets (see lib/persistence/diff.ts).
//
// `prisma generate` runs offline from this file — no database is required to
// build the app. A live DATABASE_URL is only needed to actually persist scans;
// without it, OUTSIDE uses the in-memory store and everything still runs.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model RateLimitBucket {
  key       String   @id
  count     Int
  expiresAt DateTime

  @@index([expiresAt])
  @@map("rate_limit_buckets")
}

model ConcurrencyLease {
  id        String   @id
  scope     String
  expiresAt DateTime

  @@index([scope, expiresAt])
  @@map("concurrency_leases")
}

model UsageEvent {
  id        String   @id
  orgId     String
  userId    String
  kind      String
  units     Int      @default(1)
  createdAt DateTime @default(now())

  @@index([orgId, kind, createdAt])
  @@index([userId, createdAt])
  @@map("usage_events")
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  name         String
  passwordHash String
  // Default verifies legacy rows during additive migration; all new password
  // signups explicitly write null until the signed verification link is used.
  emailVerifiedAt DateTime? @default(now())
  createdAt    DateTime     @default(now())
  memberships  Membership[]

  @@map("users")
}

model Organization {
  id                   String       @id @default(cuid())
  name                 String
  slug                 String
  plan                 String       @default("free")
  stripeCustomerId     String?      @unique
  stripeSubscriptionId String?
  subscriptionStatus   String?
  createdAt            DateTime     @default(now())
  memberships          Membership[]
  monitors             Monitor[]
  invites              Invite[]

  @@map("organizations")
}

model Membership {
  userId        String
  orgId         String
  role          String       @default("viewer")
  notifyChanges Boolean      @default(true)
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  org           Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@id([userId, orgId])
  @@map("memberships")
}

model Invite {
  id         String       @id @default(cuid())
  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId      String
  email      String
  role       String       @default("analyst")
  // Transitional nullable columns allow an existing db-push deployment to add
  // hashed tokens without making legacy plaintext tokens usable. The legacy
  // token column can be dropped after operators run the security migration.
  token      String?      @unique
  tokenHash  String?      @unique
  createdBy  String       @default("legacy")
  createdAt  DateTime     @default(now())
  expiresAt  DateTime     @default(now())
  acceptedAt DateTime?
  revokedAt  DateTime?

  @@index([orgId, acceptedAt, expiresAt])
  @@map("invites")
}

model Monitor {
  id         String       @id @default(cuid())
  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId      String
  domain     String
  frequency  String       @default("daily")
  enabled    Boolean      @default(true)
  lastScanAt DateTime?
  nextRunAt  DateTime
  createdAt  DateTime     @default(now())
  leaseId    String?
  leaseUntil DateTime?
  attempts   Int          @default(0)
  lastError  String?

  @@unique([orgId, domain])
  @@index([enabled, nextRunAt, leaseUntil])
  @@map("monitors")
}

model Target {
  id         String          @id @default(cuid())
  domain     String          @unique
  createdAt  DateTime        @default(now())
  scans      Scan[]
  identities AssetIdentity[]

  @@map("targets")
}

model Scan {
  id         String         @id
  target     Target         @relation(fields: [targetId], references: [id], onDelete: Cascade)
  targetId   String
  finishedAt DateTime
  mode       String
  scoreValue Int
  assetCount Int
  snapshots  AssetSnapshot[]

  @@index([targetId, finishedAt])
  @@map("scans")
}

model AssetIdentity {
  id          String          @id @default(cuid())
  target      Target          @relation(fields: [targetId], references: [id], onDelete: Cascade)
  targetId    String
  canonical   String
  label       String
  firstSeenAt DateTime
  lastSeenAt  DateTime
  snapshots   AssetSnapshot[]

  @@unique([targetId, canonical])
  @@map("asset_identities")
}

model AIAnalysis {
  id        String   @id @default(cuid())
  scanId    String?
  target    String
  kind      String
  source    String
  text      String
  createdAt DateTime @default(now())

  @@index([target])
  @@map("ai_analyses")
}

model RecommendationState {
  orgId     String
  target    String
  recId     String
  status    String
  updatedAt DateTime @updatedAt

  @@id([orgId, target, recId])
  @@index([orgId, target])
  @@map("recommendation_states")
}

model AuditEvent {
  id        String   @id @default(cuid())
  target    String?
  orgId     String?
  actor     String?
  action    String
  detail    String?
  createdAt DateTime @default(now())

  @@index([target])
  @@map("audit_events")
}

model ProcessedEvent {
  id        String   @id
  createdAt DateTime @default(now())

  @@map("processed_events")
}

model DomainVerification {
  domain     String    @id
  token      String
  status     String    @default("pending")
  orgId      String?
  createdAt  DateTime  @default(now())
  verifiedAt DateTime?

  @@map("domain_verifications")
}

model AssetSnapshot {
  id           String        @id @default(cuid())
  scan         Scan          @relation(fields: [scanId], references: [id], onDelete: Cascade)
  scanId       String
  identity     AssetIdentity @relation(fields: [identityId], references: [id], onDelete: Cascade)
  identityId   String
  canonical    String
  label        String
  kind         String
  priority     String
  technologies String[]
  status       String?
  present      Boolean       @default(true)

  @@index([scanId])
  @@index([identityId])
  @@map("asset_snapshots")
}
